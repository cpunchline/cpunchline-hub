prefix=/home/cpunchline/cpunchline-hub/tools/pre_built
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: libzmq
Description: 0MQ c++ library
Version: 4.3.6
Libs: -L${libdir} -lzmq
Libs.private: -lstdc++  -lrt
Requires.private: 
Cflags: -I${includedir} -DZMQ_BUILD_DRAFT_API=1
