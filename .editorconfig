# editor config
root = true

[{*.{h,hxx,hpp,c,cc,cxx,cpp,ipp,txt}}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 8

[{*.sh,Makefile,Makefile.*}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = tab
indent_size = 4

[*.{py,rs}]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4


[*.yaml]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2